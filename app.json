{
  "expo": {
    "name": "UMOVE ANNABA",
    "slug": "umove-annaba",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "umoveannaba",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A3D8F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.umoveannaba",
      "config": {
        "googleMapsApiKey": "EXPO_PUBLIC_GOOGLE_MAPS_API_KEY_PLACEHOLDER"
      }
    },
    "android": {
      "package": "com.umoveannaba",
      "googleServicesFile": "./google-services.json",
      "config": {
        "googleMaps": {
          "apiKey": "EXPO_PUBLIC_GOOGLE_MAPS_API_KEY_PLACEHOLDER"
        }
      },
      "adaptiveIcon": {
        "backgroundColor": "#0A3D8F",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "react-native-maps",
        {
          "googleMapsApiKey": "EXPO_PUBLIC_GOOGLE_MAPS_API_KEY_PLACEHOLDER"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
